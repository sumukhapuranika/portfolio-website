---
import BaseLayout from '../layouts/BaseLayout.astro';
import { certifications, education, profile, projects, stackGroups, timeline } from '../data/portfolio';
---

<BaseLayout title="Resume | Sumukha Puranika">
  <main class="section-shell py-16">
    <a href="/" class="focus-ring inline-flex rounded-full border border-white/10 px-4 py-2 text-sm text-zinc-300 transition hover:bg-white/5 hover:text-white">
      Back to portfolio
    </a>

    <section class="mt-12 max-w-4xl">
      <p class="eyebrow">{profile.location}</p>
      <h1 class="mt-4 text-4xl font-extrabold tracking-normal text-white sm:text-5xl">{profile.name}</h1>
      <p class="mt-3 text-xl text-zinc-300">Data Engineer and Backend Developer</p>
      <div class="mt-5 flex flex-wrap gap-3 text-sm text-zinc-400">
        <a class="hover:text-white" href={`mailto:${profile.email}`}>{profile.email}</a>
        <span>{profile.phone}</span>
        <a class="hover:text-white" href={profile.github}>GitHub</a>
        <a class="hover:text-white" href={profile.linkedin}>LinkedIn</a>
      </div>
    </section>

    <section class="mt-12 max-w-4xl border-t border-white/10 pt-8">
      <h2 class="text-xl font-semibold text-white">Summary</h2>
      <p class="mt-3 leading-7 text-zinc-400">{profile.intro} {profile.mission}</p>
    </section>

    <section class="mt-10 max-w-4xl border-t border-white/10 pt-8">
      <h2 class="text-xl font-semibold text-white">Experience</h2>
      <div class="mt-5 space-y-6">
        <article>
          <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
            <h3 class="font-semibold text-white">Software Engineer · Cognizant</h3>
            <p class="text-sm text-zinc-500">June 2024 - Current</p>
          </div>
          <p class="mt-3 leading-7 text-zinc-400">{timeline[0].description}</p>
        </article>
      </div>
    </section>

    <section class="mt-10 max-w-4xl border-t border-white/10 pt-8">
      <h2 class="text-xl font-semibold text-white">Skills</h2>
      <div class="mt-5 grid gap-4 sm:grid-cols-2">
        {
          stackGroups.map((group) => (
            <div class="rounded-lg border border-white/10 p-4">
              <h3 class="font-semibold text-white">{group.title}</h3>
              <p class="mt-2 text-sm leading-6 text-zinc-400">{group.items.join(', ')}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mt-10 max-w-4xl border-t border-white/10 pt-8">
      <h2 class="text-xl font-semibold text-white">Projects</h2>
      <div class="mt-5 space-y-6">
        {
          projects.map((project) => (
            <article>
              <h3 class="font-semibold text-white">{project.title}</h3>
              <p class="mt-2 leading-7 text-zinc-400">{project.description}</p>
              <p class="mt-2 text-sm text-zinc-500">{project.tech.join(', ')}</p>
              <a class="mt-2 inline-flex text-sm text-accent-soft hover:text-white" href={project.github}>
                {project.github}
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="mt-10 max-w-4xl border-t border-white/10 pt-8">
      <h2 class="text-xl font-semibold text-white">Education</h2>
      <div class="mt-5 flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
        <div>
          <h3 class="font-semibold text-white">{education.school}</h3>
          <p class="mt-1 text-zinc-400">{education.degree}</p>
        </div>
        <p class="text-sm text-zinc-500">{education.location} · {education.year}</p>
      </div>
    </section>

    <section class="mt-10 max-w-4xl border-t border-white/10 pt-8">
      <h2 class="text-xl font-semibold text-white">Certifications</h2>
      <ul class="mt-4 space-y-2 text-zinc-400">
        {certifications.map((certification) => <li>{certification}</li>)}
      </ul>
    </section>
  </main>
</BaseLayout>
